<script>
/* ========== Reveal on scroll ========== */
const io = new IntersectionObserver((entries)=>{
  entries.forEach(e=>{ if(e.isIntersecting){ e.target.classList.add('show'); io.unobserve(e.target);} });
},{threshold:.12});
document.querySelectorAll('.reveal').forEach(el=>io.observe(el));

/* ========== Instagram embeds — ленивая загрузка + обрезка нижней панели ========== */
(function(){
  const ig=document.getElementById('instagram');
  if(!ig) return;
  let loaded=false;
  // Срезаем нижний бар эмбеда (лайки/комментарии/«ещё в Instagram») — он внутри iframe,
  // поэтому прячем через overflow:hidden, уменьшая высоту контейнера.
  const HEADER=56, CHROME=170;
  function cropIG(){
    document.querySelectorAll('.ig-crop').forEach(function(w){
      const f=w.querySelector('iframe');
      if(f && f.offsetHeight>260){ w.style.height=(f.offsetHeight-HEADER-CHROME)+'px'; }
    });
  }
  function scheduleCrop(){ [400,1200,2500,4500,7000].forEach(function(t){ setTimeout(cropIG,t); }); }
  function loadIG(){
    if(loaded) return; loaded=true;
    function done(){ if(window.instgrm && window.instgrm.Embeds) window.instgrm.Embeds.process(); scheduleCrop(); }
    if(window.instgrm && window.instgrm.Embeds){ done(); return; }
    const s=document.createElement('script');
    s.async=true; s.src='https://www.instagram.com/embed.js';
    s.onload=done;
    document.body.appendChild(s);
  }
  let ct;
  window.addEventListener('resize',function(){ clearTimeout(ct); ct=setTimeout(cropIG,200); });
  if('IntersectionObserver' in window){
    const igo=new IntersectionObserver((entries)=>{
      entries.forEach(e=>{ if(e.isIntersecting){ loadIG(); igo.disconnect(); } });
    },{rootMargin:'400px'});
    igo.observe(ig);
  } else { loadIG(); }
})();

/* ========== Scroll-to-top ========== */
const toTop=document.getElementById('to-top');
if(toTop){
  window.addEventListener('scroll',()=>{ toTop.classList.toggle('show', window.scrollY>600); },{passive:true});
  toTop.addEventListener('click',()=>window.scrollTo({top:0,behavior:'smooth'}));
}

/* ========== Контакт-хаб (Telegram + онлайн-чат + звонок) ========== */
const fabHub=document.getElementById('fab-hub');
const fabMain=document.getElementById('fab-main');
if(fabHub && fabMain){
  const closeHub=()=>{ fabHub.classList.remove('open'); fabMain.setAttribute('aria-expanded','false'); };
  fabMain.addEventListener('click',(e)=>{
    e.stopPropagation();
    const open=fabHub.classList.toggle('open');
    fabMain.setAttribute('aria-expanded', open?'true':'false');
  });
  document.addEventListener('click',(e)=>{ if(!fabHub.contains(e.target)) closeHub(); });
  document.addEventListener('keydown',(e)=>{ if(e.key==='Escape') closeHub(); });
  const fabChat=document.getElementById('fab-chat');
  if(fabChat){
    fabChat.addEventListener('click',()=>{
      if(window.Tawk_API){
        if(Tawk_API.showWidget) Tawk_API.showWidget();
        if(Tawk_API.maximize) Tawk_API.maximize();
      }
      closeHub();
    });
  }
}

/* ========== Footer «Написать» → онлайн-чат ========== */
const footerChat=document.getElementById('footer-chat');
if(footerChat){
  footerChat.addEventListener('click',()=>{
    if(window.Tawk_API && Tawk_API.maximize){
      if(Tawk_API.showWidget) Tawk_API.showWidget();
      Tawk_API.maximize();
    } else {
      const c=document.getElementById('contact');
      if(c) c.scrollIntoView({behavior:'smooth'});
    }
  });
}

/* ========== Phone input mask (+998 __ ___ __ __) ========== */
const phoneInput=document.querySelector('input[name="Phone"]');
if(phoneInput){
  phoneInput.addEventListener('input',()=>{
    let d=phoneInput.value.replace(/\D/g,'');
    if(d.startsWith('998')) d=d.slice(3);
    d=d.slice(0,9);
    let out='+998';
    if(d.length) out+=' '+d.slice(0,2);
    if(d.length>2) out+=' '+d.slice(2,5);
    if(d.length>5) out+=' '+d.slice(5,7);
    if(d.length>7) out+=' '+d.slice(7,9);
    phoneInput.value=out;
  });
}

/* ========== Tab buttons (calc / chips / lang) ========== */
function setupGroup(sel){
  document.querySelectorAll(sel).forEach(group=>{
    group.querySelectorAll('button,.chip').forEach(btn=>{
      btn.addEventListener('click',()=>{
        group.querySelectorAll('button,.chip').forEach(b=>b.classList.remove('active'));
        btn.classList.add('active');
        if(group.classList.contains('form-chips')){
          const hidden = document.getElementById('chip-value');
          if(hidden) hidden.value = btn.textContent.trim();
        }
        if(sel.startsWith('#') && sel.includes('opts')) updateCalc();
      });
    });
  });
}
['#type-opts','#print-opts','#size-opts','.form-chips','.lang'].forEach(setupGroup);

/* ========== Клик по карточке товара → форма с выбранным типом ========== */
document.querySelectorAll('.product[data-product]').forEach(card=>{
  card.addEventListener('click', ()=>{
    const name = card.dataset.product;
    const chips = [...document.querySelectorAll('.form-chips .chip')];
    let matched = false;
    chips.forEach(c=>{
      const on = c.textContent.trim() === name;
      c.classList.toggle('active', on);
      if(on) matched = true;
    });
    if(!matched){
      const other = chips.find(c=>c.textContent.trim()===T.other);
      if(other) other.classList.add('active');
    }
    const hidden = document.getElementById('chip-value');
    if(hidden) hidden.value = name;
    const contact = document.getElementById('contact');
    if(contact) contact.scrollIntoView({behavior:'smooth'});
  });
});

/* ========== i18n strings (rendered per language) ========== */
const T = {
  sending: "{{ ui.js.sending | safe }}",
  sent: "{{ ui.js.sent | safe }}",
  fail: "{{ ui.js.fail | safe }}",
  neterr: "{{ ui.js.neterr | safe }}",
  other: "{{ ui.form.other | safe }}",
  c_type: "{{ ui.js.c_type | safe }}",
  c_print: "{{ ui.js.c_print | safe }}",
  c_qty: "{{ ui.js.c_qty | safe }}",
  c_size: "{{ ui.js.c_size | safe }}",
  c_pcs: "{{ ui.js.c_pcs | safe }}"
};
const LOCALE = "{{ ui.js.locale }}";

/* ========== Configurator — only summarizes user's choices, no prices ========== */
const fmt = n => n.toLocaleString(LOCALE).replace(/[,  ]/g,' ');
function updateCalc(){
  const type  = document.querySelector('#type-opts .active').dataset.val;
  const print = document.querySelector('#print-opts .active').dataset.val;
  const size  = document.querySelector('#size-opts .active').dataset.val;
  const qty   = +document.getElementById('qty').value;
  document.getElementById('qty-out').textContent = fmt(qty);
  document.getElementById('r-qty').textContent  = fmt(qty);
  document.getElementById('r-type').textContent  = type;
  document.getElementById('r-print').textContent = print;
  document.getElementById('r-size').textContent  = size;
  const cta = document.getElementById('calc-cta');
  if(cta){
    cta.onclick = (e)=>{
      e.preventDefault();
      const chips = document.querySelectorAll('.form-chips .chip');
      chips.forEach(c=>{
        c.classList.toggle('active', c.textContent.trim() === type);
      });
      const hidden = document.getElementById('chip-value');
      if(hidden) hidden.value = type;
      const ta = document.querySelector('textarea.form-control');
      if(ta) ta.value = `${T.c_type}: ${type}\n${T.c_print}: ${print}\n${T.c_qty}: ${fmt(qty)} ${T.c_pcs}\n${T.c_size}: ${size}`;
      const qtyInput = document.querySelector('input[name="Quantity"]');
      if(qtyInput) qtyInput.value = fmt(qty);
      // Visible confirmation: show note, scroll, flash the form, focus name
      const note = document.getElementById('calc-note');
      if(note) note.hidden = false;
      const contact = document.getElementById('contact');
      if(contact) contact.scrollIntoView({behavior:'smooth'});
      const form = document.querySelector('.contact-form');
      if(form){ form.classList.remove('flash'); void form.offsetWidth; form.classList.add('flash'); }
      setTimeout(()=>{ const n=document.querySelector('input[name="Name"]'); if(n) n.focus({preventScroll:true}); }, 700);
    };
  }
}
document.getElementById('qty').addEventListener('input',updateCalc);
updateCalc();

/* ========== FAQ accordion ========== */
document.querySelectorAll('.faq-item').forEach(item=>{
  item.querySelector('.faq-q').addEventListener('click',()=>{
    const isOpen = item.classList.contains('open');
    document.querySelectorAll('.faq-item').forEach(i=>i.classList.remove('open'));
    if(!isOpen) item.classList.add('open');
  });
});

/* ========== Lightbox for certificates ========== */
const lb = document.getElementById('lightbox');
const lbImg = document.getElementById('lightbox-img');
const lbDl  = lb.querySelector('.lightbox-download');
document.querySelectorAll('.cert[data-img]').forEach(c=>{
  c.addEventListener('click',()=>{
    lbImg.src = c.dataset.img;
    lbDl.href = c.dataset.pdf || c.dataset.img;
    lb.classList.add('open');
    document.body.style.overflow='hidden';
  });
});
function closeLb(){ lb.classList.remove('open'); document.body.style.overflow=''; }
lb.querySelector('.lightbox-close').addEventListener('click',closeLb);
lb.addEventListener('click',e=>{ if(e.target===lb) closeLb(); });
document.addEventListener('keydown',e=>{ if(e.key==='Escape') closeLb(); });

/* ========== Mobile burger ========== */
document.querySelector('.burger').addEventListener('click',()=>{
  const nav = document.querySelector('.nav');
  if(nav.style.display === 'flex'){ nav.style.display=''; }
  else { nav.style.cssText='display:flex;flex-direction:column;position:absolute;top:78px;left:0;right:0;background:var(--bg);padding:30px 28px;gap:20px;border-bottom:1px solid var(--line)'; }
});

/* ========== Lead form → Web3Forms (заявки на почту) ========== */
const leadForm = document.querySelector('.contact-form');
if(leadForm){
  leadForm.addEventListener('submit', async (e)=>{
    e.preventDefault();
    const btn = leadForm.querySelector('button[type=submit]');
    const orig = btn.innerHTML;
    btn.disabled = true; btn.textContent = T.sending;
    const fd = new FormData(leadForm);
    try{
      const res = await fetch('https://api.web3forms.com/submit', {
        method:'POST',
        headers:{'Accept':'application/json'},
        body:fd
      });
      const data = await res.json();
      if(data.success){
        const g = k => (fd.get(k) || '—');
        const tgText = '🛍 Новая заявка — Alpha Plast\n\n'
          + '👤 Имя: ' + g('Name') + '\n'
          + '🏢 Компания: ' + g('Company') + '\n'
          + '📞 Телефон: ' + g('Phone') + '\n'
          + '📦 Интересует: ' + g('Product') + '\n'
          + '🔢 Тираж: ' + g('Quantity') + '\n'
          + '💬 Комментарий: ' + g('Comment');
        fetch('https://api.telegram.org/bot8837051167:AAHl-I-7kRr2deWKD_4Y4YkQg3SlxoTp24c/sendMessage', {
          method:'POST',
          headers:{'Content-Type':'application/x-www-form-urlencoded'},
          body:'chat_id=1234571697&text=' + encodeURIComponent(tgText)
        }).catch(function(){});
        leadForm.reset();
        alert(T.sent);
      } else {
        alert(T.fail);
      }
    } catch(err){
      alert(T.neterr);
    } finally {
      btn.disabled = false; btn.innerHTML = orig;
    }
  });
}
</script>
{%- if cfg.chat_src %}
<!-- Онлайн-консультант (чат) Tawk.to — родной пузырь прячем, открываем из контакт-хаба -->
<script>
window.Tawk_API = window.Tawk_API || {};
Tawk_API.onLoad = function(){ if(Tawk_API.hideWidget) Tawk_API.hideWidget(); };
Tawk_API.onChatMinimized = function(){ if(Tawk_API.hideWidget) Tawk_API.hideWidget(); };

/* Уведомление в Telegram-бот о сообщениях из онлайн-чата (все сценарии) */
function tawkTG(text){
  fetch('https://api.telegram.org/bot8837051167:AAHl-I-7kRr2deWKD_4Y4YkQg3SlxoTp24c/sendMessage', {
    method:'POST',
    headers:{'Content-Type':'application/x-www-form-urlencoded'},
    body:'chat_id=1234571697&disable_web_page_preview=true&text=' + encodeURIComponent(text)
  }).catch(function(){});
}
function tawkFmt(data){
  if(!data) return '';
  if(typeof data === 'string') return data;
  if(Array.isArray(data)){
    return data.map(function(f){
      var k=(f&&(f.label||f.name||f.key))||''; var v=(f&&(f.answer||f.value||f.text))||'';
      return (k?k+': ':'')+v;
    }).join('\n');
  }
  var out=[];
  if(data.name) out.push('👤 '+data.name);
  if(data.email) out.push('✉️ '+data.email);
  if(data.phone) out.push('📞 '+data.phone);
  if(data.message) out.push('📝 '+data.message);
  if(data.text) out.push('📝 '+data.text);
  if(out.length) return out.join('\n');
  try { return JSON.stringify(data); } catch(e){ return ''; }
}
/* 1) Живой чат (оператор онлайн) — пинг на каждое сообщение клиента */
Tawk_API.onChatMessageVisitor = function(message){
  tawkTG('💬 Клиент в онлайн-чате (Alpha Plast):\n' + (tawkFmt(message) || '(без текста)'));
};
/* 2) Офлайн-сообщение (никто не онлайн) */
Tawk_API.onOfflineSubmit = function(data){
  tawkTG('📩 Офлайн-сообщение с сайта Alpha Plast (чат)\n\n' + (tawkFmt(data) || '(без данных)') + '\n\n↩️ Ответить: dashboard.tawk.to или по контактам клиента');
};
/* 3) Пречат-форма (имя/вопрос перед чатом) */
Tawk_API.onPrechatSubmit = function(data){
  tawkTG('📝 Пречат-форма на сайте Alpha Plast\n\n' + (tawkFmt(data) || '(без данных)') + '\n\n↩️ dashboard.tawk.to');
};
</script>
<script src="{{ cfg.chat_src }}" async></script>
{%- endif %}
</body>
