{%- set page_path = '/' -%}
{%- set og_locale = 'uz_UZ' -%}
{%- if lang == 'ru' -%}{%- set page_path = '/ru.html' -%}{%- set og_locale = 'ru_RU' -%}{%- endif -%}
{%- if lang == 'en' -%}{%- set page_path = '/en.html' -%}{%- set og_locale = 'en_US' -%}{%- endif -%}
<!DOCTYPE html>
<html lang="{{ lang }}">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">

{%- if cfg.ga_id %}
<!-- Google tag (gtag.js) -->
<script async src="https://www.googletagmanager.com/gtag/js?id={{ cfg.ga_id }}"></script>
<script>
  window.dataLayer = window.dataLayer || [];
  function gtag(){dataLayer.push(arguments);}
  gtag('js', new Date());
  gtag('config', '{{ cfg.ga_id }}');
</script>
{%- endif %}
{%- if cfg.metrika_id %}
<!-- Yandex.Metrika counter -->
<script type="text/javascript">
  (function(m,e,t,r,i,k,a){m[i]=m[i]||function(){(m[i].a=m[i].a||[]).push(arguments)};
  m[i].l=1*new Date();
  for (var j=0;j<document.scripts.length;j++){if(document.scripts[j].src===r){return;}}
  k=e.createElement(t),a=e.getElementsByTagName(t)[0],k.async=1,k.src=r,a.parentNode.insertBefore(k,a)})
  (window, document,"script","https://mc.yandex.ru/metrika/tag.js","ym");
  ym({{ cfg.metrika_id }}, "init", {clickmap:true,trackLinks:true,accurateTrackBounce:true,webvisor:true});
</script>
<noscript><div><img src="https://mc.yandex.ru/watch/{{ cfg.metrika_id }}" style="position:absolute;left:-9999px;" alt="" /></div></noscript>
<!-- /Yandex.Metrika counter -->
{%- endif %}

<title>{{ site.meta.title }}</title>
<meta name="description" content="{{ site.meta.description }}">
{%- if site.meta.keywords %}
<meta name="keywords" content="{{ site.meta.keywords }}">
{%- endif %}
<link rel="icon" type="image/png" href="assets/logo-mark.png">
<link rel="apple-touch-icon" href="assets/logo-mark.png">
<link rel="canonical" href="{{ cfg.base_url }}{{ page_path }}">

<link rel="alternate" hreflang="uz" href="{{ cfg.base_url }}/">
<link rel="alternate" hreflang="ru" href="{{ cfg.base_url }}/ru.html">
<link rel="alternate" hreflang="en" href="{{ cfg.base_url }}/en.html">
<link rel="alternate" hreflang="x-default" href="{{ cfg.base_url }}/">

<meta property="og:type" content="website">
<meta property="og:site_name" content="Alpha Plast">
<meta property="og:title" content="{{ site.meta.title }}">
<meta property="og:description" content="{{ site.meta.description }}">
<meta property="og:url" content="{{ cfg.base_url }}{{ page_path }}">
<meta property="og:image" content="{{ cfg.base_url }}/assets/og-cover.jpg">
<meta property="og:image:width" content="1200">
<meta property="og:image:height" content="630">
<meta property="og:locale" content="{{ og_locale }}">
<meta name="twitter:card" content="summary_large_image">
<meta name="twitter:title" content="{{ site.meta.title }}">
<meta name="twitter:description" content="{{ site.meta.description }}">
<meta name="twitter:image" content="{{ cfg.base_url }}/assets/og-cover.jpg">

<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "Organization",
  "name": "ALPHA PLAST GROUP FACTORY",
  "url": "{{ cfg.base_url }}/",
  "logo": "{{ cfg.base_url }}/assets/logo-full.png",
  "image": "{{ cfg.base_url }}/assets/og-cover.jpg",
  "description": {{ site.meta.description | dump | safe }},
  "areaServed": "Uzbekistan",
  "email": "{{ site.contact.email }}",
  "telephone": "{{ site.header.phone_display }}",
  "address": {
    "@type": "PostalAddress",
    "addressLocality": "Tashkent",
    "addressRegion": "Tashkent",
    "addressCountry": "UZ",
    "streetAddress": "Zargarlik 26, Uchtepa"
  },
  "sameAs": ["{{ site.contact.telegram }}", "{{ site.contact.telegram_channel }}", "{{ site.contact.instagram }}"]
}
</script>

<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {%- for item in site.faq.items %}
    {
      "@type": "Question",
      "name": {{ item.q | dump | safe }},
      "acceptedAnswer": { "@type": "Answer", "text": {{ item.a | dump | safe }} }
    }{% if not loop.last %},{% endif %}
    {%- endfor %}
  ]
}
</script>

<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Rubik:wght@500;600;700;800&family=Plus+Jakarta+Sans:wght@400;500;600;700;800&family=Instrument+Serif:ital@0;1&display=swap" rel="stylesheet">

<style>
/* ==============================
   ALPHA PLAST — premium redesign
   ============================== */
:root{
  --bg:        #F4F1EA;
  --bg-2:      #EAE5D9;
  --ink:       #0E1014;
  --ink-2:     #1A1D24;
  --muted:     #6B7280;
  --line:      rgba(14,16,20,.10);
  --line-2:    rgba(14,16,20,.06);
  --accent:    #E11E1E;
  --accent-2:  #FFD1D1;
  --accent-dk: #B81212;
  --green:     #1F6B4B;
  --paper:     #FFFFFF;
  --radius:    22px;
  --radius-sm: 14px;
  --shadow:    0 30px 60px -30px rgba(14,16,20,.25);
  --shadow-sm: 0 10px 30px -20px rgba(14,16,20,.4);
  --container: 1240px;
  --font-display: "Rubik", "Plus Jakarta Sans", sans-serif;
  --font-text:    "Plus Jakarta Sans", system-ui, sans-serif;
  --font-serif:   "Instrument Serif", Georgia, serif;
}
*{box-sizing:border-box;margin:0;padding:0}
html,body{background:var(--bg);color:var(--ink);font-family:var(--font-text);font-size:16px;line-height:1.55;-webkit-font-smoothing:antialiased;scroll-behavior:smooth}
img{max-width:100%;display:block}
a{color:inherit;text-decoration:none}
button{font:inherit;cursor:pointer;border:0;background:transparent;color:inherit}
input,textarea,select{font:inherit;color:inherit}
.container{max-width:var(--container);margin:0 auto;padding:0 28px}
.eyebrow{display:inline-flex;align-items:center;gap:10px;font-size:12px;font-weight:600;letter-spacing:.18em;text-transform:uppercase;color:var(--muted)}
.eyebrow::before{content:"";width:24px;height:1px;background:var(--ink);opacity:.4}
h1,h2,h3,h4{font-family:var(--font-display);font-weight:600;letter-spacing:-.02em;line-height:1.05}
h2{font-size:clamp(34px,4.5vw,64px)}
h3{font-size:clamp(22px,2.2vw,28px);font-weight:600}
.serif{font-family:var(--font-serif);font-style:italic;font-weight:400}
.btn{display:inline-flex;align-items:center;gap:10px;padding:16px 26px;border-radius:999px;font-weight:600;font-size:15px;transition:transform .25s ease,background .25s,color .25s,box-shadow .25s;white-space:nowrap}
.btn-primary{background:var(--ink);color:#fff}
.btn-primary:hover{background:var(--accent);transform:translateY(-2px);box-shadow:0 16px 30px -16px rgba(225,30,30,.6)}
.btn-accent{background:var(--accent);color:#fff}
.btn-accent:hover{background:var(--ink);transform:translateY(-2px)}
.btn-ghost{background:transparent;color:var(--ink);border:1px solid var(--line)}
.btn-ghost:hover{background:var(--ink);color:#fff;border-color:var(--ink)}
.btn .arrow{display:inline-block;transition:transform .25s}
.btn:hover .arrow{transform:translateX(4px)}

/* === TOP BAR === */
.topbar{background:var(--ink);color:#fff;font-size:13px}
.topbar .container{display:flex;justify-content:space-between;align-items:center;height:42px;gap:24px}
.topbar a,.topbar .left span{opacity:.8;transition:opacity .2s}
.topbar a:hover{opacity:1}
.topbar .left{display:flex;gap:20px;align-items:center;flex-wrap:wrap}
.topbar .right{display:flex;gap:14px;align-items:center}
.lang{display:flex;gap:2px;background:rgba(255,255,255,.08);padding:3px;border-radius:999px}
.lang button,.lang a{padding:4px 10px;border-radius:999px;font-size:12px;font-weight:600;color:#fff;opacity:.6;cursor:pointer}
.lang button.active,.lang a.active{background:var(--accent);opacity:1}

/* === HEADER === */
.header{position:sticky;top:0;z-index:50;background:rgba(244,241,234,.85);backdrop-filter:saturate(180%) blur(16px);-webkit-backdrop-filter:saturate(180%) blur(16px);border-bottom:1px solid var(--line-2)}
.header .container{display:flex;align-items:center;justify-content:space-between;height:78px;gap:18px}
.logo{display:flex;align-items:center;gap:10px;font-family:var(--font-display);font-weight:700;font-size:22px;letter-spacing:-.02em}
.logo-mark{width:38px;height:38px;border-radius:12px;background:var(--ink);display:grid;place-items:center;color:var(--accent);font-weight:800;font-size:18px;letter-spacing:-.04em;position:relative;overflow:hidden}
.logo-mark::after{content:"";position:absolute;inset:0;background:radial-gradient(circle at 70% 20%,rgba(225,30,30,.35),transparent 60%)}
.nav{display:flex;gap:22px}
.nav a{font-weight:500;font-size:14.5px;color:var(--ink);opacity:.78;transition:opacity .2s,color .2s;position:relative;white-space:nowrap}
.nav a:hover{opacity:1;color:var(--accent)}
.header-cta{display:flex;align-items:center;gap:14px}
.header-phone{font-weight:700;font-size:15px;color:var(--ink);white-space:nowrap}
.burger{display:none;flex-direction:column;gap:5px;width:30px;height:30px;justify-content:center;align-items:flex-end}
.burger span{width:24px;height:2px;background:var(--ink);border-radius:2px}
.burger span:nth-child(2){width:18px}

/* === HERO === */
.hero{position:relative;overflow:hidden;padding:80px 0 120px}
.hero::before{content:"";position:absolute;top:-20%;right:-10%;width:55%;height:120%;background:radial-gradient(circle,rgba(225,30,30,.18),transparent 65%);pointer-events:none;z-index:0}
.hero .container{position:relative;z-index:1;display:grid;grid-template-columns:1.05fr .95fr;gap:60px;align-items:center}
.hero .container.hero-stats-wrap{display:block}
.hero-tag{display:inline-flex;align-items:center;gap:10px;background:#fff;padding:8px 14px 8px 10px;border-radius:999px;font-size:13px;font-weight:600;box-shadow:var(--shadow-sm);margin-bottom:28px}
.hero-tag .dot{width:8px;height:8px;border-radius:50%;background:#22C55E;box-shadow:0 0 0 4px rgba(34,197,94,.2)}
.hero h1{font-size:clamp(48px,5.5vw,70px);line-height:1.02;letter-spacing:-.035em;font-weight:600;font-family:var(--font-display)}
.hero h1 .accent{color:var(--accent);position:relative;white-space:nowrap}
.hero h1 .accent::after{content:"";position:absolute;left:0;right:0;bottom:6px;height:14px;background:var(--accent-2);z-index:-1;border-radius:4px}
.hero h1 .serif{display:inline-block}
.hero p.lead{font-size:19px;color:var(--muted);max-width:520px;margin:28px 0 36px;line-height:1.55}
.hero-ctas{display:flex;gap:14px;flex-wrap:wrap;align-items:center;margin-bottom:48px}
.hero-rating{display:flex;align-items:center;gap:12px}
.hero-avatars{display:flex}
.hero-avatars span{width:38px;height:38px;border-radius:50%;border:3px solid var(--bg);margin-left:-12px;display:grid;place-items:center;font-weight:700;font-size:13px;color:#fff}
.hero-avatars span:first-child{margin-left:0}
.hero-avatars span:nth-child(1){background:#E11E1E}
.hero-avatars span:nth-child(2){background:#1F6B4B}
.hero-avatars span:nth-child(3){background:#0E1014}
.hero-avatars span:nth-child(4){background:#D4AF37}
.hero-rating-text{font-size:13px;color:var(--muted);line-height:1.3}
.hero-rating-text b{display:block;color:var(--ink);font-size:14px}
.hero-stars{color:var(--accent);font-size:14px;letter-spacing:1px}

/* Hero visual */
.hero-visual{position:relative;aspect-ratio:1/1.05}
.hero-card{position:absolute;background:#fff;border-radius:24px;padding:18px;box-shadow:var(--shadow);display:flex;align-items:center;gap:12px;font-weight:600;font-size:14px;z-index:3}
.hero-card .ic{width:42px;height:42px;border-radius:12px;display:grid;place-items:center;flex-shrink:0}
.hero-card.c1{top:8%;left:-4%;}
.hero-card.c1 .ic{background:#FFD1D1;color:#E11E1E}
.hero-card.c2{bottom:14%;left:-2%}
.hero-card.c2 .ic{background:#D7EFE3;color:#1F6B4B}
.hero-card.c3{top:24%;right:-2%}
.hero-card.c3 .ic{background:#0E1014;color:#fff}
.hero-card small{display:block;color:var(--muted);font-weight:500;font-size:12px;margin-top:2px}
.hero-bag{position:absolute;inset:8% 8% 8% 8%;background:linear-gradient(180deg,#F03A3A 0%,#E11E1E 60%,#B81212 100%);border-radius:36px;display:flex;flex-direction:column;justify-content:space-between;padding:40px 36px;color:#fff;overflow:hidden;box-shadow:0 50px 100px -40px rgba(225,30,30,.6)}
.hero-bag::before{content:"";position:absolute;top:-20px;left:50%;transform:translateX(-50%);width:140px;height:60px;background:#E11E1E;border-radius:0 0 90px 90px;border:8px solid var(--bg);border-top:0;box-shadow:inset 0 -8px 0 rgba(0,0,0,.15)}
.hero-bag::after{content:"";position:absolute;top:-10px;left:50%;transform:translateX(-50%);width:80px;height:30px;background:transparent;border:6px solid var(--ink);border-bottom:0;border-radius:80px 80px 0 0;z-index:2}
.hero-bag-logo{margin-top:30px;font-family:var(--font-display);font-size:42px;font-weight:700;letter-spacing:-.04em;line-height:.9}
.hero-bag-logo span{display:block;font-size:14px;font-weight:500;letter-spacing:.4em;opacity:.8;margin-top:6px}
.hero-bag-foot{font-size:13px;opacity:.7;letter-spacing:.2em;text-transform:uppercase}
.hero-bag-deco{position:absolute;bottom:-30px;right:-30px;width:200px;height:200px;border-radius:50%;background:radial-gradient(circle,rgba(255,255,255,.2),transparent 60%)}

/* Stat strip below hero */
.stat-strip{display:grid;grid-template-columns:repeat(4,1fr);gap:0;background:var(--ink);color:#fff;border-radius:24px;overflow:hidden;margin-top:-60px;position:relative;z-index:5}
.stat-strip > div{padding:30px 28px;border-right:1px solid rgba(255,255,255,.08)}
.stat-strip > div:last-child{border-right:0}
.stat-strip b{font-family:var(--font-display);font-size:42px;font-weight:600;letter-spacing:-.03em;display:block;line-height:1;white-space:nowrap}
.stat-strip b .plus{color:var(--accent);display:inline;font-size:22px;margin:0 0 0 2px;vertical-align:baseline}
.stat-strip span{display:block;font-size:15px;opacity:.7;margin-top:10px;line-height:1.4}

/* === SECTIONS === */
section{padding:120px 0;position:relative}
.section-head{display:flex;justify-content:space-between;align-items:end;gap:40px;margin-bottom:60px;flex-wrap:wrap}
.section-head .left{max-width:680px}
.section-head h2{margin-top:18px}
.section-head h2 .serif{color:var(--accent)}
.section-head p{color:var(--muted);font-size:17px;margin-top:18px;max-width:520px}

/* === PRODUCTS === */
.products-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:20px}
.product{background:#fff;border-radius:var(--radius);overflow:hidden;display:flex;flex-direction:column;transition:transform .35s ease,box-shadow .35s;cursor:pointer;border:1px solid var(--line-2)}
.product:hover{transform:translateY(-6px);box-shadow:var(--shadow)}
.product-img{aspect-ratio:1.1/1;display:grid;place-items:center;position:relative;overflow:hidden}
.product-img.c1{background:linear-gradient(135deg,#FFD1D1,#E11E1E)}
.product-img.c2{background:linear-gradient(135deg,#D7EFE3,#1F6B4B)}
.product-img.c3{background:linear-gradient(135deg,#FCE7C8,#D4AF37)}
.product-img.c4{background:linear-gradient(135deg,#E6E2D3,#A89776)}
.product-img.c5{background:linear-gradient(135deg,#E5D5FF,#7B5BD9)}
.product-img.c6{background:linear-gradient(135deg,#D7E8FF,#4A7CD9)}
.product-img{background:#fff}
.product-img img{position:absolute;inset:0;width:100%;height:100%;object-fit:cover}
.product-svg{width:55%;height:65%;position:relative;display:flex;align-items:flex-end;justify-content:center}
/* schematic plastic bag */
.bag-shape{width:100%;height:90%;background:rgba(255,255,255,.95);border-radius:6px 6px 14px 14px;position:relative;box-shadow:0 20px 40px -20px rgba(0,0,0,.3);display:grid;place-items:center;font-family:var(--font-display);font-weight:700;font-size:24px;color:var(--ink);letter-spacing:-.04em}
.bag-shape::before,.bag-shape::after{content:"";position:absolute;top:-22px;width:30%;height:30px;background:transparent;border:7px solid rgba(255,255,255,.95);border-bottom:0;border-radius:30px 30px 0 0}
.bag-shape::before{left:8%}
.bag-shape::after{right:8%}
.bag-shape.paper{background:#E8DCC3;color:#5A4318;box-shadow:inset 0 -20px 0 rgba(0,0,0,.05),0 20px 40px -20px rgba(0,0,0,.4)}
.bag-shape.paper::before,.bag-shape.paper::after{border-color:#5A4318;border-width:3px;width:25%;height:24px;top:-18px;background:transparent}
.bag-shape.nonwoven{background:#fff;color:var(--green)}
.product-tag{position:absolute;top:18px;left:18px;background:#fff;color:var(--ink);padding:6px 12px;border-radius:999px;font-size:12px;font-weight:700;letter-spacing:.04em}
.product-info{padding:24px 24px 26px;display:flex;flex-direction:column;gap:6px;flex:1}
.product-info h3{font-size:22px;letter-spacing:-.02em}
.product-info p{color:var(--muted);font-size:14px;line-height:1.5}
.product-foot{display:flex;justify-content:space-between;align-items:center;margin-top:14px;padding-top:14px;border-top:1px solid var(--line-2)}
.product-price{font-weight:700;font-size:15px}
.product-price small{display:block;font-weight:500;color:var(--muted);font-size:11px;margin-top:2px}
.product-arrow{width:38px;height:38px;border-radius:50%;background:var(--bg);display:grid;place-items:center;transition:background .25s,color .25s,transform .25s}
.product:hover .product-arrow{background:var(--accent);color:#fff;transform:rotate(-45deg)}

/* === BENEFITS === */
.benefits{background:var(--ink);color:#fff;border-radius:36px;margin:0 28px;padding:100px 60px;position:relative;overflow:hidden}
.benefits::before{content:"";position:absolute;top:-30%;right:-10%;width:60%;height:140%;background:radial-gradient(circle,rgba(225,30,30,.25),transparent 60%);pointer-events:none}
.benefits .container{padding:0;position:relative}
.benefits .section-head h2{color:#fff}
.benefits .section-head p{color:rgba(255,255,255,.6)}
.benefits-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:1px;background:rgba(255,255,255,.08);border-radius:24px;overflow:hidden;border:1px solid rgba(255,255,255,.08)}
.benefit{background:var(--ink);padding:40px 30px;transition:background .3s}
.benefit:hover{background:var(--ink-2)}
.benefit-num{font-family:var(--font-display);font-size:14px;font-weight:600;color:var(--accent);letter-spacing:.1em;margin-bottom:30px}
.benefit-ic{width:54px;height:54px;border-radius:14px;background:rgba(225,30,30,.12);color:var(--accent);display:grid;place-items:center;margin-bottom:22px}
.benefit h3{color:#fff;font-size:23px;margin-bottom:12px}
.benefit p{color:rgba(255,255,255,.78);font-size:16px;line-height:1.6}

/* === CALCULATOR === */
.calc-wrap{display:grid;grid-template-columns:1.05fr .95fr;gap:60px;align-items:stretch}
.calc-form{background:#fff;border-radius:var(--radius);padding:44px;display:flex;flex-direction:column;gap:24px;box-shadow:var(--shadow-sm)}
.calc-row{display:flex;flex-direction:column;gap:10px}
.calc-row label{font-size:13px;font-weight:700;letter-spacing:.06em;text-transform:uppercase;color:var(--muted)}
.calc-options{display:grid;grid-template-columns:repeat(3,1fr);gap:8px}
.calc-opt{padding:14px 10px;text-align:center;border:1px solid var(--line);border-radius:14px;font-size:14px;font-weight:600;background:#fff;transition:all .2s}
.calc-opt:hover{border-color:var(--ink)}
.calc-opt.active{background:var(--ink);color:#fff;border-color:var(--ink)}
.calc-row input[type=range]{width:100%;accent-color:var(--accent);height:6px}
.calc-row .range-out{font-family:var(--font-display);font-size:32px;font-weight:600;letter-spacing:-.02em}
.calc-row .range-out span{color:var(--accent)}
.calc-result{background:linear-gradient(180deg,#E11E1E,#B81212);color:#fff;border-radius:var(--radius);padding:44px;display:flex;flex-direction:column;justify-content:space-between;position:relative;overflow:hidden}
.calc-result::after{content:"";position:absolute;top:-50px;right:-50px;width:200px;height:200px;border-radius:50%;background:rgba(255,255,255,.1)}
.calc-result h3{color:#fff;font-size:18px;font-weight:600;opacity:.85}
.calc-price{font-family:var(--font-display);font-size:84px;font-weight:600;letter-spacing:-.04em;line-height:1;margin:40px 0}
.calc-price small{font-size:18px;font-weight:500;opacity:.7}
.calc-breakdown{display:flex;flex-direction:column;gap:10px;border-top:1px solid rgba(255,255,255,.2);padding-top:24px;margin-bottom:24px;font-size:14px}
.calc-breakdown div{display:flex;justify-content:space-between;opacity:.85}
.calc-breakdown div b{font-weight:700;opacity:1}
.calc-result .btn{background:#fff;color:var(--ink);align-self:flex-start}
.calc-result .btn:hover{background:var(--ink);color:#fff}

/* === PROCESS === */
.process{background:linear-gradient(180deg,var(--bg) 0%,var(--bg-2) 100%)}
.process-grid{display:grid;grid-template-columns:repeat(6,1fr);gap:14px;position:relative}
.process-step{background:#fff;border-radius:var(--radius-sm);padding:26px 22px;position:relative;border:1px solid var(--line-2);transition:transform .3s}
.process-step:hover{transform:translateY(-4px);box-shadow:var(--shadow-sm)}
.process-step .num{font-family:var(--font-display);font-size:14px;color:var(--accent);font-weight:700;letter-spacing:.1em;margin-bottom:20px}
.process-step .ic{width:44px;height:44px;margin-bottom:18px;font-size:32px;line-height:1}
.process-step h3{font-size:18px;letter-spacing:-.02em;margin-bottom:8px}
.process-step p{font-size:13px;color:var(--muted);line-height:1.5}

/* === ABOUT / STATS === */
.about{background:var(--ink);color:#fff;border-radius:36px;margin:0 28px;padding:120px 60px;position:relative;overflow:hidden}
.about-grid{display:grid;grid-template-columns:1fr 1fr;gap:80px;align-items:center}
.about-img{aspect-ratio:1/1.1;border-radius:24px;background:linear-gradient(135deg,#F03A3A,#E11E1E 50%,#1F6B4B);position:relative;overflow:hidden;display:grid;place-items:center}
.about-img-inner{width:60%;aspect-ratio:.8/1;background:#F4F1EA;border-radius:14px;position:relative;display:flex;flex-direction:column;justify-content:center;align-items:center;color:var(--ink);padding:30px}
.about-img-inner::before,.about-img-inner::after{content:"";position:absolute;top:-20px;width:25%;height:30px;border:7px solid #F4F1EA;border-bottom:0;border-radius:24px 24px 0 0;background:transparent}
.about-img-inner::before{left:10%}
.about-img-inner::after{right:10%}
.about-img-inner .big{font-family:var(--font-display);font-size:48px;font-weight:700;letter-spacing:-.04em;line-height:.9;color:var(--ink)}
.about-img-inner .big span{color:var(--accent)}
.about-img-inner .sub{font-size:12px;letter-spacing:.3em;opacity:.6;margin-top:10px;text-transform:uppercase}
.about-video{position:relative;width:calc(100% + 76px);margin-left:-76px;aspect-ratio:16/9;border-radius:24px;overflow:hidden;box-shadow:0 40px 80px -40px rgba(0,0,0,.6);background:#000}
.about-video iframe{position:absolute;inset:0;width:100%;height:100%;border:0}
.about h2{color:#fff;margin-top:18px}
.about h2 .serif{color:var(--accent)}
.about p.about-text{color:rgba(255,255,255,.65);font-size:17px;margin-top:24px;line-height:1.7}
.about-stats{display:grid;grid-template-columns:repeat(3,1fr);gap:24px;margin-top:48px;padding-top:40px;border-top:1px solid rgba(255,255,255,.12)}
.about-stat b{font-family:var(--font-display);font-size:54px;font-weight:600;letter-spacing:-.04em;color:#fff;display:block;line-height:1}
.about-stat b .plus{color:var(--accent)}
.about-stat span{font-size:13px;color:rgba(255,255,255,.55);margin-top:8px;display:block}

/* === CASES === */
.cases-grid{display:grid;grid-template-columns:2fr 1fr 1fr;grid-template-rows:1fr 1fr;gap:16px;height:560px}
.case{border-radius:var(--radius);overflow:hidden;position:relative;display:flex;align-items:flex-end;padding:28px;color:#fff;font-weight:600;cursor:pointer;transition:transform .35s}
.case:hover{transform:scale(1.01)}
.case-photo{position:absolute;inset:0;width:100%;height:100%;object-fit:cover;z-index:0}
.case::before{content:"";position:absolute;inset:0;background:linear-gradient(180deg,transparent 35%,rgba(0,0,0,.78));z-index:1}
.case .case-content{position:relative;z-index:2}
.case .client{font-size:24px;font-family:var(--font-display);letter-spacing:-.02em}
.case .meta{font-size:13px;opacity:.8;margin-top:4px;font-weight:500}
.case.c1{grid-row:1/3;background:linear-gradient(135deg,#0F2D52,#1565C0)}
.case.c2{background:linear-gradient(135deg,#1F6B4B,#0F4D32)}
.case.c3{background:linear-gradient(135deg,#E11E1E,#B81212)}
.case.c4{background:linear-gradient(135deg,#0E1014,#3A3F4B)}
.case.c5{background:linear-gradient(135deg,#D4AF37,#8B7218)}
.case-bag{position:absolute;top:8%;left:50%;transform:translateX(-50%);width:55%;aspect-ratio:.85/1;background:rgba(255,255,255,.95);border-radius:8px;display:grid;place-items:center;color:var(--ink);font-family:var(--font-display);font-weight:700;letter-spacing:-.03em;text-align:center;padding:20px;font-size:22px}
.case.c1 .case-bag{font-size:34px}
.case-bag::before,.case-bag::after{content:"";position:absolute;top:-18px;width:25%;height:24px;border:5px solid rgba(255,255,255,.95);border-bottom:0;border-radius:24px 24px 0 0;background:transparent}
.case-bag::before{left:10%}
.case-bag::after{right:10%}

/* === CERTIFICATES === */
.certs-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:20px}
.cert{background:#fff;border-radius:var(--radius);overflow:hidden;display:flex;flex-direction:column;cursor:pointer;border:1px solid var(--line-2);transition:transform .35s ease,box-shadow .35s}
.cert:hover{transform:translateY(-6px);box-shadow:var(--shadow)}
.cert-img{aspect-ratio:1.1/1;background:linear-gradient(135deg,#F4F1EA,#EAE5D9);display:grid;place-items:center;padding:24px;overflow:hidden;position:relative}
.cert-img img{max-width:88%;max-height:88%;object-fit:contain;box-shadow:0 24px 50px -22px rgba(0,0,0,.35);border-radius:4px;transition:transform .5s ease}
.cert:hover .cert-img img{transform:scale(1.04)}
.cert-img::after{content:"🔍";position:absolute;bottom:14px;right:14px;background:rgba(14,16,20,.85);color:#fff;font-size:11px;font-weight:600;padding:6px 12px;border-radius:999px;opacity:0;transition:opacity .25s;letter-spacing:.04em}
.cert:hover .cert-img::after{opacity:1}
.cert-info{padding:24px 26px 28px;display:flex;flex-direction:column;gap:8px;flex:1}
.cert-tag{font-size:11px;font-weight:700;letter-spacing:.12em;text-transform:uppercase;color:var(--accent)}
.cert-info h3{font-size:20px;letter-spacing:-.02em}
.cert-info p{font-size:14px;color:var(--muted);line-height:1.55}
.cert-cta{background:var(--ink);color:#fff;cursor:default}
.cert-cta:hover{transform:translateY(-6px)}
.cert-cta-inner{padding:40px 32px;display:flex;flex-direction:column;justify-content:center;height:100%;gap:14px;position:relative;overflow:hidden}
.cert-cta-inner::before{content:"";position:absolute;top:-30%;right:-20%;width:80%;height:140%;background:radial-gradient(circle,rgba(225,30,30,.35),transparent 60%)}
.cert-cta-inner h3{color:#fff;font-size:26px;position:relative}
.cert-cta-inner p{color:rgba(255,255,255,.65);font-size:15px;position:relative;margin-bottom:10px}
.cert-cta-inner .btn{background:var(--accent);color:#fff;align-self:flex-start;position:relative}
.cert-cta-inner .btn:hover{background:#fff;color:var(--ink)}

/* Lightbox */
.lightbox{position:fixed;inset:0;background:rgba(14,16,20,.92);backdrop-filter:blur(10px);display:none;align-items:center;justify-content:center;z-index:100;padding:60px 40px}
.lightbox.open{display:flex}
.lightbox img{max-width:100%;max-height:100%;object-fit:contain;box-shadow:0 50px 120px -30px rgba(0,0,0,.7);border-radius:6px}
.lightbox-close{position:absolute;top:24px;right:30px;background:rgba(255,255,255,.1);color:#fff;width:48px;height:48px;border-radius:50%;font-size:28px;font-weight:300;line-height:1;display:grid;place-items:center;transition:all .2s}
.lightbox-close:hover{background:var(--accent);transform:rotate(90deg)}
.lightbox-download{position:absolute;top:30px;left:30px;background:var(--accent);color:#fff;padding:12px 22px;border-radius:999px;font-weight:600;font-size:14px;transition:background .2s}
.lightbox-download:hover{background:#fff;color:var(--ink)}

/* === FAQ === */
.faq-wrap{display:grid;grid-template-columns:1fr 1.4fr;gap:80px;align-items:start}
.faq-side h2{margin-top:18px}
.faq-side p{color:var(--muted);margin:20px 0 30px;font-size:17px}
.faq-list{display:flex;flex-direction:column;gap:12px}
.faq-item{background:#fff;border-radius:var(--radius-sm);border:1px solid var(--line-2);padding:0 28px;overflow:hidden;transition:all .3s}
.faq-item.open{background:var(--ink);color:#fff;border-color:var(--ink)}
.faq-q{display:flex;justify-content:space-between;align-items:center;padding:24px 0;cursor:pointer;font-weight:600;font-size:17px;gap:20px}
.faq-q .ic{width:32px;height:32px;border-radius:50%;background:var(--bg);display:grid;place-items:center;flex-shrink:0;transition:all .3s;font-size:18px;font-weight:300}
.faq-item.open .faq-q .ic{background:var(--accent);color:#fff;transform:rotate(45deg)}
.faq-a{max-height:0;overflow:hidden;transition:max-height .35s ease,padding .3s,opacity .3s;color:rgba(255,255,255,.7);opacity:0}
.faq-item.open .faq-a{max-height:300px;padding:0 0 26px;opacity:1}
.faq-a p{font-size:15px;line-height:1.6}

/* === CTA BIG === */
.cta-big{padding:60px 0 120px}
.cta-card{background:linear-gradient(135deg,#F03A3A,#E11E1E);color:#fff;border-radius:36px;padding:80px 60px;display:flex;justify-content:space-between;align-items:center;gap:60px;flex-wrap:wrap;position:relative;overflow:hidden;box-shadow:0 50px 100px -40px rgba(225,30,30,.5)}
.cta-card::before{content:"";position:absolute;top:-50%;left:-10%;width:60%;height:200%;background:radial-gradient(circle,rgba(255,255,255,.15),transparent 60%)}
.cta-card h2{color:#fff;max-width:640px;position:relative}
.cta-card h2 .serif{color:var(--accent-2)}
.cta-card p{color:rgba(255,255,255,.85);max-width:520px;margin-top:18px;font-size:17px;position:relative}
.cta-card .btn{position:relative;background:#fff;color:var(--ink)}
.cta-card .btn:hover{background:var(--ink);color:#fff}

/* === CONTACT === */
.contact-grid{display:grid;grid-template-columns:.95fr 1.05fr;gap:60px;align-items:start}
.contact-info h2{margin-top:18px}
.contact-info > p{color:var(--muted);margin:22px 0 36px;font-size:17px;max-width:440px}
.contact-list{display:flex;flex-direction:column;gap:20px;margin-bottom:32px}
.contact-item{display:flex;gap:18px;align-items:flex-start;padding:24px;background:#fff;border-radius:var(--radius-sm);border:1px solid var(--line-2);transition:transform .25s}
.contact-item:hover{transform:translateY(-2px);box-shadow:var(--shadow-sm)}
.contact-item .ic{width:50px;height:50px;border-radius:14px;background:var(--accent);color:#fff;display:grid;place-items:center;flex-shrink:0}
.contact-item h4{font-family:var(--font-display);font-size:17px;font-weight:600;margin-bottom:6px}
.contact-item p,.contact-item a{font-size:14px;color:var(--muted);display:block;line-height:1.55}
.contact-item a{color:var(--ink);font-weight:600;font-size:15px}
.contact-socials{display:flex;gap:10px}
.soc{width:44px;height:44px;border-radius:50%;background:#fff;border:1px solid var(--line);display:grid;place-items:center;transition:all .2s}
.soc:hover{background:var(--ink);color:#fff;border-color:var(--ink);transform:translateY(-2px)}
.contact-form{background:#fff;border-radius:var(--radius);padding:44px;box-shadow:var(--shadow-sm)}
.contact-form.flash{animation:formFlash 1.1s ease-out}
@keyframes formFlash{0%{box-shadow:0 0 0 0 rgba(225,30,30,.5)}70%{box-shadow:0 0 0 16px rgba(225,30,30,0)}100%{box-shadow:var(--shadow-sm)}}
.calc-note{display:flex;gap:8px;align-items:flex-start;background:rgba(22,163,74,.10);border:1px solid rgba(22,163,74,.35);color:#14794a;border-radius:12px;padding:13px 16px;font-size:14px;font-weight:600;line-height:1.45;margin-bottom:26px}
.calc-note[hidden]{display:none}
.contact-form h3{margin-bottom:8px}
.contact-form > p{color:var(--muted);font-size:14px;margin-bottom:28px}
.form-row{display:flex;flex-direction:column;gap:8px;margin-bottom:18px}
.form-row.two{display:grid;grid-template-columns:1fr 1fr;gap:14px}
.form-row label{font-size:12px;font-weight:700;letter-spacing:.08em;text-transform:uppercase;color:var(--muted)}
.form-control{padding:14px 16px;border:1px solid var(--line);border-radius:12px;font-size:15px;background:#fff;transition:border-color .2s,box-shadow .2s;width:100%}
.form-control:focus{outline:none;border-color:var(--accent);box-shadow:0 0 0 4px rgba(225,30,30,.12)}
textarea.form-control{resize:vertical;min-height:110px;font-family:var(--font-text)}
.form-chips{display:flex;gap:8px;flex-wrap:wrap}
.chip{padding:10px 16px;border:1px solid var(--line);border-radius:999px;font-size:13px;font-weight:600;background:#fff;transition:all .2s;cursor:pointer}
.chip:hover{border-color:var(--ink)}
.chip.active{background:var(--ink);color:#fff;border-color:var(--ink)}
.form-submit{width:100%;justify-content:center;margin-top:8px}
.form-policy{font-size:12px;color:var(--muted);margin-top:14px;text-align:center}
.form-policy a{color:var(--accent);text-decoration:underline}

/* === FOOTER === */
footer{background:var(--ink);color:#fff;padding:80px 0 30px}
/* Footer CTA row */
.footer-cta{display:flex;justify-content:space-between;align-items:center;gap:30px;flex-wrap:wrap;padding-bottom:40px;margin-bottom:48px;border-bottom:1px solid rgba(255,255,255,.10)}
.footer-cta h2{color:#fff;font-size:clamp(28px,3vw,42px)}
.footer-cta-right{display:flex;align-items:center;gap:26px;flex-wrap:wrap}
.footer-cta-right p{color:rgba(255,255,255,.6);font-size:15px;max-width:360px;line-height:1.5}
/* Footer main: Instagram + contacts */
.footer-main{display:grid;grid-template-columns:minmax(0,1.5fr) minmax(0,1fr);gap:56px;margin-bottom:56px;align-items:start}
.footer-ig{min-width:0}
.ig-profile{display:flex;align-items:center;gap:14px;margin-bottom:20px}
.ig-avatar{flex-shrink:0;width:54px;height:54px;border-radius:50%;overflow:hidden;background:#fff;display:grid;place-items:center;border:2px solid rgba(255,255,255,.15)}
.ig-avatar img{width:78%;height:78%;object-fit:contain}
.ig-profile-info{flex:1;min-width:0;display:flex;flex-direction:column;gap:2px}
.ig-name{color:#fff;font-weight:700;font-size:16px;font-family:var(--font-display);line-height:1.15;transition:color .2s}
.ig-name:hover{color:var(--accent)}
.ig-handle{color:rgba(255,255,255,.55);font-size:13px}
.ig-stats{display:flex;gap:16px;margin-top:6px;flex-wrap:wrap}
.ig-stats span{color:rgba(255,255,255,.6);font-size:12px}
.ig-stats b{color:#fff;font-weight:700;font-size:13px}
.ig-follow{flex-shrink:0;display:inline-flex;align-items:center;gap:7px;background:#0095F6;color:#fff;font-weight:600;font-size:13px;padding:9px 16px;border-radius:10px;white-space:nowrap;transition:filter .2s,transform .2s}
.ig-follow:hover{filter:brightness(1.08);transform:translateY(-1px)}
.ig-grid-footer{display:grid;grid-template-columns:repeat(2,minmax(0,1fr));gap:18px;align-items:start}
.ig-crop{overflow:hidden;border-radius:14px;background:#fff;box-shadow:0 12px 30px -18px rgba(0,0,0,.5);min-width:0}
.ig-crop .instagram-media{min-width:0 !important;width:100% !important;max-width:100% !important;margin:0 !important;border:0 !important;border-radius:0 !important;box-shadow:none !important;transform:translateY(-56px)}
.ig-crop iframe{min-width:0 !important;width:100% !important;max-width:100% !important}
.footer-contacts{display:flex;flex-direction:column;gap:18px}
.footer-contacts .logo{align-self:flex-start;margin-bottom:2px}
.footer-cline{display:flex;flex-direction:column;gap:3px}
.footer-cline b{font-size:12px;text-transform:uppercase;letter-spacing:.1em;color:rgba(255,255,255,.5);font-weight:600;margin-bottom:4px}
.footer-cline a,.footer-cline span{color:rgba(255,255,255,.85);font-size:15px;transition:color .2s}
.footer-cline a:hover{color:var(--accent)}
.footer-tagline{color:#fff;font-weight:600;font-size:15px;line-height:1.55;margin-top:4px;max-width:320px}
.footer-socials-bottom{display:flex;gap:12px}
.footer-socials-bottom a{width:34px;height:34px;border-radius:50%;border:1px solid rgba(255,255,255,.15);display:grid;place-items:center;color:rgba(255,255,255,.7);transition:background .2s,color .2s,border-color .2s}
.footer-socials-bottom a:hover{background:#fff;color:var(--ink);border-color:#fff}
.footer-bottom{padding-top:30px;border-top:1px solid rgba(255,255,255,.08);display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:20px;color:rgba(255,255,255,.4);font-size:13px}
.footer-bottom a:hover{color:#fff}

/* ============== RESPONSIVE ============== */
@media (max-width: 1240px){
  .nav{gap:16px}
  .nav a{font-size:13.5px}
  .header .container{gap:14px}
  .header-phone{display:none}
}
@media (max-width: 1024px){
  .hero .container{grid-template-columns:1fr;gap:40px}
  .hero-visual{aspect-ratio:1.4/1;max-width:460px;margin:0 auto}
  .hero-card{display:none}
  .nav{display:none}
  .burger{display:flex}
  .stat-strip{grid-template-columns:repeat(2,1fr)}
  .stat-strip > div:nth-child(2){border-right:0}
  .products-grid,.benefits-grid,.reviews-grid,.certs-grid{grid-template-columns:repeat(2,1fr)}
  .process-grid{grid-template-columns:repeat(3,1fr)}
  .calc-wrap,.about-grid,.faq-wrap,.contact-grid{grid-template-columns:1fr;gap:40px}
  .about-video{width:100%;margin-left:0;height:auto;aspect-ratio:16/9;min-height:0}
  .about{padding:80px 40px}
  .benefits{padding:80px 40px}
  .cases-grid{grid-template-columns:1fr 1fr;grid-template-rows:auto;height:auto}
  .case.c1{grid-row:auto;aspect-ratio:1/1}
  .case{aspect-ratio:1/1}
  .footer-main{grid-template-columns:minmax(0,1fr);gap:44px}
}
@media (max-width: 720px){
  section{padding:80px 0}
  .topbar .left > :not(:first-child){display:none}
  .hero{padding:50px 0 100px}
  .hero h1{font-size:clamp(26px,8.6vw,46px)}
  .products-grid,.benefits-grid,.reviews-grid,.process-grid,.certs-grid{grid-template-columns:1fr}
  .stat-strip{grid-template-columns:1fr}
  .stat-strip > div{border-right:0;border-bottom:1px solid rgba(255,255,255,.08)}
  .cta-card{padding:50px 30px;flex-direction:column;align-items:flex-start}
  .contact-form,.calc-form,.calc-result{padding:30px}
  .calc-price{font-size:60px}
  .about{padding:60px 24px;margin:0 14px}
  .benefits{padding:60px 24px;margin:0 14px}
  .cta-card{padding:50px 28px}
  .container{padding:0 18px}
  .footer-cta{flex-direction:column;align-items:flex-start;gap:20px}
  .footer-cta-right{width:100%;justify-content:space-between}
  .cases-grid{grid-template-columns:1fr}
}
/* Footer Instagram: stack posts on small screens */
@media (max-width: 560px){
  .ig-grid-footer{grid-template-columns:minmax(0,1fr);max-width:360px}
}

/* Very narrow phones (≤380px): prevent grid blowout / horizontal scroll */
@media (max-width: 380px){
  .about-grid > *{min-width:0}
  .about-stats{grid-template-columns:repeat(3,minmax(0,1fr));gap:12px}
  .about-stat{min-width:0}
  .about-stat b{font-size:32px}
  .about-stat span{font-size:11px}
  .calc-wrap > *{min-width:0}
  .calc-options{grid-template-columns:repeat(2,1fr)}
  .calc-opt{min-width:0}
}

/* Map */
.map-wrap{margin-top:40px;border-radius:var(--radius);overflow:hidden;border:1px solid var(--line-2);box-shadow:var(--shadow-sm)}
.map-wrap iframe{display:block;width:100%;height:420px;border:0}
@media(max-width:720px){.map-wrap iframe{height:320px}}

/* Floating contact hub (Telegram + онлайн-чат + звонок в одной кнопке) */
.fab-hub{position:fixed;right:22px;bottom:22px;z-index:60;display:flex;align-items:center;gap:12px}
.fab-items{display:flex;align-items:center;gap:12px}
.fab-item{width:50px;height:50px;border-radius:50%;display:grid;place-items:center;color:#fff;box-shadow:0 10px 24px -8px rgba(0,0,0,.45);opacity:0;transform:scale(.4) translateY(6px);pointer-events:none;transition:opacity .22s ease,transform .22s ease;border:none;cursor:pointer}
.fab-hub.open .fab-item{opacity:1;transform:none;pointer-events:auto}
.fab-item:hover{filter:brightness(1.08)}
.fab-item svg{width:26px;height:26px}
.fab-tg{background:#229ED9}
.fab-chat{background:#16a34a}
.fab-call{background:var(--accent)}
.fab-main{position:relative;width:58px;height:58px;border-radius:50%;background:var(--ink);color:#fff;display:grid;place-items:center;cursor:pointer;border:none;box-shadow:0 12px 30px -8px rgba(0,0,0,.5);transition:transform .25s ease,background .25s}
.fab-main:hover{transform:translateY(-2px)}
.fab-hub.open .fab-main{background:var(--accent)}
.fab-main svg{width:28px;height:28px;transition:opacity .2s,transform .2s}
.fab-ic-close{position:absolute;font-size:22px;line-height:1;opacity:0;transform:rotate(-90deg);transition:opacity .2s,transform .2s}
.fab-hub.open .fab-ic-open{opacity:0;transform:rotate(90deg)}
.fab-hub.open .fab-ic-close{opacity:1;transform:none}
.fab-dot{position:absolute;top:2px;right:2px;width:13px;height:13px;border-radius:50%;background:#16a34a;border:2px solid var(--bg);animation:fabPulse 2s infinite}
.fab-hub.open .fab-dot{display:none}
@keyframes fabPulse{0%{box-shadow:0 0 0 0 rgba(22,163,74,.55)}70%{box-shadow:0 0 0 8px rgba(22,163,74,0)}100%{box-shadow:0 0 0 0 rgba(22,163,74,0)}}
@media(max-width:720px){.fab-hub{right:16px;bottom:16px;gap:10px}.fab-items{gap:10px}.fab-main{width:54px;height:54px}.fab-item{width:46px;height:46px}.fab-item svg{width:23px;height:23px}}
/* Scroll-to-top */
.to-top{position:fixed;right:24px;bottom:92px;z-index:60;width:46px;height:46px;border-radius:50%;background:var(--ink);color:#fff;display:grid;place-items:center;font-size:20px;line-height:1;border:none;cursor:pointer;opacity:0;visibility:hidden;transform:translateY(10px);transition:opacity .25s,transform .25s,visibility .25s,background .2s;box-shadow:0 10px 24px -8px rgba(0,0,0,.45)}
.to-top.show{opacity:1;visibility:visible;transform:none}
.to-top:hover{background:var(--accent)}
@media(max-width:720px){.to-top{right:16px;bottom:80px;width:42px;height:42px}}

/* Reveal on scroll */
.reveal{opacity:0;transform:translateY(30px);transition:opacity .8s ease,transform .8s ease}
.reveal.show{opacity:1;transform:translateY(0)}
</style>
</head>
<body>

<!-- ================== TOPBAR ================== -->
<div class="topbar">
  <div class="container">
    <div class="left">
      <a href="mailto:{{ site.topbar.email }}">📧 {{ site.topbar.email }}</a>
      <a href="https://yandex.uz/maps/?text={{ site.topbar.address | urlencode }}" target="_blank" rel="noopener">📍 {{ site.topbar.address }}</a>
      <span>🕘 {{ site.topbar.hours }}</span>
    </div>
    <div class="right">
      <div class="lang">
        <a href="./" class="{% if lang == 'uz' %}active{% endif %}">UZ</a>
        <a href="ru.html" class="{% if lang == 'ru' %}active{% endif %}">RU</a>
        <a href="en.html" class="{% if lang == 'en' %}active{% endif %}">EN</a>
      </div>
    </div>
  </div>
</div>

<!-- ================== HEADER ================== -->
<header class="header">
  <div class="container">
    <a href="./" class="logo">
      <img src="assets/logo-full.png" alt="Alpha Plast" style="height:54px;width:auto;display:block">
    </a>
    <nav class="nav">
      <a href="#products">{{ ui.nav.products }}</a>
      <a href="#calc">{{ ui.nav.calc }}</a>
      <a href="#process">{{ ui.nav.process }}</a>
      <a href="#cases">{{ ui.nav.cases }}</a>
      <a href="#certs">{{ ui.nav.certs }}</a>
      <a href="#about">{{ ui.nav.about }}</a>
      <a href="#contact">{{ ui.nav.contact }}</a>
    </nav>
    <div class="header-cta">
      <a href="tel:{{ site.header.phone_link }}" class="header-phone">{{ site.header.phone_display }}</a>
      <a href="#contact" class="btn btn-primary">{{ site.header.cta_text }} <span class="arrow">→</span></a>
      <button class="burger" aria-label="menu"><span></span><span></span><span></span></button>
    </div>
  </div>
</header>

<!-- ================== HERO ================== -->
<section class="hero">
  <div class="container">
    <div class="hero-left reveal">
      <div class="hero-tag">
        <span class="dot"></span> {{ site.hero.tag }}
      </div>
      <h1>
        {{ site.hero.title_line1 }}{% if site.hero.title_serif %} <span class="serif">{{ site.hero.title_serif }}</span>{% endif %}<br>
        <span class="accent">{{ site.hero.title_accent }}</span><br>
        {{ site.hero.title_line3 }}
      </h1>
      <p class="lead">
        {{ site.hero.lead }}
      </p>
      <div class="hero-ctas">
        <a href="#calc" class="btn btn-accent">{{ site.hero.cta_primary }} <span class="arrow">→</span></a>
        <a href="#products" class="btn btn-ghost">{{ site.hero.cta_secondary }}</a>
      </div>
      <div class="hero-rating">
        <div class="hero-avatars">
          <span>S</span><span>A</span><span>H</span><span>N</span>
        </div>
        <div class="hero-rating-text">
          <span class="hero-stars">★★★★★</span>
          <b>{{ site.hero.rating_title }}</b>
          {{ site.hero.rating_sub }}
        </div>
      </div>
    </div>

    <div class="hero-visual reveal">
      {% for card in site.hero.cards %}
      <div class="hero-card c{{ loop.index }}">
        <div class="ic">{{ card.icon }}</div>
        <div>{{ card.title }}<small>{{ card.sub }}</small></div>
      </div>
      {% endfor %}
      <div class="hero-bag">
        <div class="hero-bag-deco"></div>
        <div class="hero-bag-foot">Premium · Eco · Custom</div>
        <div style="background:#fff;padding:18px 26px;border-radius:18px;align-self:flex-start;box-shadow:0 20px 50px -20px rgba(0,0,0,.3)">
          <img src="assets/logo-full.png" alt="Alpha Plast" style="height:80px;width:auto;display:block">
        </div>
        <div class="hero-bag-foot">Made in Tashkent</div>
      </div>
    </div>
  </div>

  <div class="container hero-stats-wrap" style="margin-top:80px">
    <div class="stat-strip reveal">
      {% for s in site.stats %}
      <div><b>{{ s.value }}<span class="plus">{{ s.plus }}</span></b><span>{{ s.label }}</span></div>
      {% endfor %}
    </div>
  </div>
</section>

<!-- ================== PRODUCTS ================== -->
<section id="products">
  <div class="container">
    <div class="section-head reveal">
      <div class="left">
        <span class="eyebrow">{{ site.products.eyebrow }}</span>
        <h2>{{ site.products.heading }}</h2>
      </div>
      <p>{{ site.products.intro }}</p>
    </div>

    <div class="products-grid reveal">
      {% for p in site.products.items %}
      <div class="product" data-product="{{ p.title }}">
        <div class="product-img">
          {% if p.tag %}<span class="product-tag">{{ p.tag }}</span>{% endif %}
          <img src="{{ p.img }}" alt="{{ p.title }} — {{ p.tag }}" loading="lazy">
        </div>
        <div class="product-info">
          <h3>{{ p.title }}</h3>
          <p>{{ p.desc }}</p>
          <div class="product-foot">
            <div class="product-price">{{ p.price }}<small>{{ p.price_sub }}</small></div>
            <div class="product-arrow">→</div>
          </div>
        </div>
      </div>
      {% endfor %}
    </div>
  </div>
</section>

<!-- ================== BENEFITS ================== -->
<div class="benefits reveal">
  <div class="container">
    <div class="section-head">
      <div class="left">
        <span class="eyebrow" style="color:rgba(255,255,255,.6)"><span style="background:rgba(255,255,255,.4)"></span>{{ site.benefits.eyebrow }}</span>
        <h2>{{ site.benefits.heading }}</h2>
      </div>
      <p>{{ site.benefits.intro }}</p>
    </div>
    <div class="benefits-grid">
      {% for b in site.benefits.items %}
      <div class="benefit">
        <div class="benefit-num">{{ b.num }}</div>
        <div class="benefit-ic">
          {% if b.icon == "factory" %}<svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 21V8l9-5 9 5v13"/><path d="M9 22V12h6v10"/></svg>
          {% elif b.icon == "shield" %}<svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
          {% elif b.icon == "award" %}<svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="8" r="7"/><polyline points="8.21 13.89 7 23 12 20 17 23 15.79 13.88"/></svg>
          {% else %}<svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>{% endif %}
        </div>
        <h3>{{ b.title }}</h3>
        <p>{{ b.desc }}</p>
      </div>
      {% endfor %}
    </div>
  </div>
</div>

<!-- ================== CONFIGURATOR ================== -->
<section id="calc">
  <div class="container">
    <div class="section-head reveal">
      <div class="left">
        <span class="eyebrow">{{ site.configurator.eyebrow }}</span>
        <h2>{{ site.configurator.heading }}</h2>
      </div>
      <p>{{ site.configurator.intro }}</p>
    </div>

    <div class="calc-wrap reveal">
      <div class="calc-form">
        <div class="calc-row">
          <label>{{ ui.configurator.type_label }}</label>
          <div class="calc-options" id="type-opts">
            {% for o in ui.configurator.types %}<button class="calc-opt{% if loop.first %} active{% endif %}" data-val="{{ o.val }}">{{ o.label }}</button>{% endfor %}
          </div>
        </div>

        <div class="calc-row">
          <label>{{ ui.configurator.print_label }}</label>
          <div class="calc-options" id="print-opts">
            {% for o in ui.configurator.prints %}<button class="calc-opt{% if loop.first %} active{% endif %}" data-val="{{ o.val }}">{{ o.label }}</button>{% endfor %}
          </div>
        </div>

        <div class="calc-row">
          <label>{{ ui.configurator.qty_label }} <span class="range-out"><span id="qty-out">10 000</span> {{ ui.configurator.pcs }}</span></label>
          <input type="range" id="qty" min="1000" max="100000" value="10000" step="1000">
        </div>

        <div class="calc-row">
          <label>{{ ui.configurator.size_label }}</label>
          <div class="calc-options" id="size-opts">
            {% for o in ui.configurator.sizes %}<button class="calc-opt{% if loop.first %} active{% endif %}" data-val="{{ o.val }}">{{ o.label }}</button>{% endfor %}
          </div>
        </div>
      </div>

      <div class="calc-result">
        <div>
          <h3>{{ ui.configurator.config_title }}</h3>
          <div class="calc-breakdown" style="border-top:0;padding-top:0;font-size:15px;margin-top:30px">
            <div><span>{{ ui.configurator.row_type }}</span><b id="r-type">{{ ui.configurator.types[0].val }}</b></div>
            <div><span>{{ ui.configurator.row_print }}</span><b id="r-print">{{ ui.configurator.prints[0].val }}</b></div>
            <div><span>{{ ui.configurator.row_qty }}</span><b><span id="r-qty">10 000</span> {{ ui.configurator.pcs }}</b></div>
            <div><span>{{ ui.configurator.row_size }}</span><b id="r-size">{{ ui.configurator.sizes[0].val }}</b></div>
            <div style="margin-top:14px;border-top:1px solid rgba(255,255,255,.2);padding-top:14px"><span>{{ ui.configurator.row_layout }}</span><b style="color:#FFD1D1">{{ ui.configurator.layout_val }}</b></div>
            <div><span>{{ ui.configurator.row_delivery }}</span><b style="color:#FFD1D1">{{ ui.configurator.delivery_val }}</b></div>
          </div>
        </div>
        <div>
          <p style="opacity:.85;font-size:14px;margin-bottom:18px">{{ site.configurator.note }}</p>
          <a href="#contact" class="btn" id="calc-cta">{{ site.configurator.cta }} <span class="arrow">→</span></a>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ================== PROCESS ================== -->
<section id="process" class="process">
  <div class="container">
    <div class="section-head reveal">
      <div class="left">
        <span class="eyebrow">{{ site.process.eyebrow }}</span>
        <h2>{{ site.process.heading }}</h2>
      </div>
      <p>{{ site.process.intro }}</p>
    </div>
    <div class="process-grid reveal">
      {% for step in site.process.steps %}
      <div class="process-step">
        <div class="num">{{ step.num }}</div>
        <div class="ic">{{ step.icon }}</div>
        <h3>{{ step.title }}</h3>
        <p>{{ step.desc }}</p>
      </div>
      {% endfor %}
    </div>
  </div>
</section>

<!-- ================== CASES ================== -->
<section id="cases">
  <div class="container">
    <div class="section-head reveal">
      <div class="left">
        <span class="eyebrow">{{ site.cases.eyebrow }}</span>
        <h2>{{ site.cases.heading }}</h2>
      </div>
      <p>{{ site.cases.intro }}</p>
    </div>

    <div class="cases-grid reveal">
      {% for c in site.cases.items %}
      <div class="case {{ c.color }}">
        {% if c.img %}<img class="case-photo" src="{{ c.img }}" alt="{{ c.client }}" loading="lazy">{% endif %}
        <div class="case-content">
          <div class="client">{{ c.client }}</div>
          <div class="meta">{{ c.meta }}</div>
        </div>
      </div>
      {% endfor %}
    </div>
  </div>
</section>

<!-- ================== ABOUT / STATS ================== -->
<div class="about reveal" id="about">
  <div class="container">
    <div class="about-grid">
      {% if site.about.video_url %}
      {% set vid = site.about.video_url | youtubeId %}
      <div class="about-video">
        <iframe src="https://www.youtube-nocookie.com/embed/{{ vid }}?autoplay=1&mute=1&loop=1&playlist={{ vid }}&playsinline=1&rel=0" title="{{ site.about.heading }}" loading="lazy" allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share" referrerpolicy="strict-origin-when-cross-origin" allowfullscreen></iframe>
      </div>
      {% else %}
      <div class="about-img">
        <div class="about-img-inner">
          <img src="assets/logo-full.png" alt="Alpha Plast" style="width:78%;max-width:300px;height:auto">
          <div class="sub" style="margin-top:24px">since 2018 · tashkent</div>
        </div>
      </div>
      {% endif %}
      <div>
        <span class="eyebrow" style="color:rgba(255,255,255,.6)">{{ site.about.eyebrow }}</span>
        <h2>{{ site.about.heading }}</h2>
        <p class="about-text">
          {{ site.about.text1 }}
        </p>
        <p class="about-text">
          {{ site.about.text2 }}
        </p>
        <div class="about-stats">
          {% for s in site.about.stats %}
          <div class="about-stat"><b>{{ s.value }}<span class="plus">{{ s.plus }}</span></b><span>{{ s.label }}</span></div>
          {% endfor %}
        </div>
      </div>
    </div>
  </div>
</div>

<!-- ================== CERTIFICATES ================== -->
<section id="certs">
  <div class="container">
    <div class="section-head reveal">
      <div class="left">
        <span class="eyebrow">{{ site.certs.eyebrow }}</span>
        <h2>{{ site.certs.heading }}</h2>
      </div>
      <p>{{ site.certs.intro }}</p>
    </div>

    <div class="certs-grid reveal">
      {% for cert in site.certs.items %}
      <div class="cert" data-img="{{ cert.img }}" data-pdf="{{ cert.pdf }}">
        <div class="cert-img"><img src="{{ cert.img }}" alt="{{ cert.title }}"></div>
        <div class="cert-info">
          <span class="cert-tag">{{ cert.tag }}</span>
          <h3>{{ cert.title }}</h3>
          <p>{{ cert.desc }}</p>
        </div>
      </div>
      {% endfor %}

      <div class="cert cert-cta">
        <div class="cert-cta-inner">
          <h3>{{ site.certs.cta_title }}</h3>
          <p>{{ site.certs.cta_text }}</p>
          <a href="#contact" class="btn btn-primary">{{ site.certs.cta_button }} <span class="arrow">→</span></a>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- Lightbox -->
<div id="lightbox" class="lightbox">
  <button class="lightbox-close" aria-label="{{ ui.lightbox_close }}">×</button>
  <a class="lightbox-download" href="#" download>{{ ui.lightbox_download }}</a>
  <img id="lightbox-img" src="" alt="">
</div>

<!-- ================== FAQ ================== -->
<section>
  <div class="container">
    <div class="faq-wrap reveal">
      <div class="faq-side">
        <span class="eyebrow">{{ site.faq.eyebrow }}</span>
        <h2>{{ site.faq.heading }}</h2>
        <p>{{ site.faq.intro }}</p>
        <a href="#contact" class="btn btn-primary">{{ site.faq.cta }} <span class="arrow">→</span></a>
      </div>
      <div class="faq-list">
        {% for item in site.faq.items %}
        <div class="faq-item{% if loop.first %} open{% endif %}">
          <div class="faq-q">{{ item.q }}<div class="ic">+</div></div>
          <div class="faq-a"><p>{{ item.a }}</p></div>
        </div>
        {% endfor %}
      </div>
    </div>
  </div>
</section>

<!-- ================== CTA BIG ================== -->
<section class="cta-big">
  <div class="container">
    <div class="cta-card reveal">
      <div>
        <h2>{{ site.cta.heading_1 }} <span class="serif">{{ site.cta.heading_serif }}</span></h2>
        <p>{{ site.cta.text }}</p>
      </div>
      <a href="#contact" class="btn">{{ site.cta.button }} <span class="arrow">→</span></a>
    </div>
  </div>
</section>

<!-- ================== CONTACT ================== -->
<section id="contact" style="padding-top:0">
  <div class="container">
    <div class="contact-grid reveal">
      <div class="contact-info">
        <span class="eyebrow">{{ site.contact.eyebrow }}</span>
        <h2>{{ site.contact.heading }}</h2>
        <p>{{ site.contact.intro }}</p>

        <div class="contact-list">
          <div class="contact-item">
            <div class="ic">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
            </div>
            <div>
              <h4>{{ ui.contact.phones }}</h4>
              {% for phone in site.contact.phones %}
              <a href="tel:{{ phone | replace(' ', '') | replace('-', '') }}">{{ phone }}</a>
              {% endfor %}
            </div>
          </div>

          <div class="contact-item">
            <div class="ic">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
            </div>
            <div>
              <h4>{{ ui.contact.email }}</h4>
              <a href="mailto:{{ site.contact.email }}">{{ site.contact.email }}</a>
              <p>{{ ui.contact.email_note }}</p>
            </div>
          </div>

          <div class="contact-item">
            <div class="ic">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
            </div>
            <div>
              <h4>{{ ui.contact.office }}</h4>
              <a href="https://yandex.uz/maps/?text={{ site.contact.address_line1 | urlencode }}" target="_blank" rel="noopener">{{ site.contact.address_line1 }}</a>
              <p>{{ site.contact.address_line2 }}</p>
            </div>
          </div>
        </div>

        <div class="contact-socials">
          <a href="{{ site.contact.telegram }}" class="soc" target="_blank" rel="noopener" aria-label="Telegram">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M21.5 4.5L2.5 12.5l5 2 2 6 3-4 5 4 4-16z"/></svg>
          </a>
          <a href="{{ site.contact.instagram }}" class="soc" target="_blank" rel="noopener" aria-label="Instagram">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="2" width="20" height="20" rx="5"/><circle cx="12" cy="12" r="4"/><circle cx="18" cy="6" r="1" fill="currentColor"/></svg>
          </a>
          {% if site.contact.youtube %}<a href="{{ site.contact.youtube }}" class="soc" target="_blank" rel="noopener" aria-label="YouTube">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M23 12s0-3.4-.4-5c-.2-.9-.9-1.6-1.8-1.8C19.2 5 12 5 12 5s-7.2 0-8.8.4c-.9.2-1.6.9-1.8 1.8C1 8.6 1 12 1 12s0 3.4.4 5c.2.9.9 1.6 1.8 1.8 1.6.4 8.8.4 8.8.4s7.2 0 8.8-.4c.9-.2 1.6-.9 1.8-1.8.4-1.6.4-5 .4-5zM9.75 15.5v-7l6 3.5-6 3.5z"/></svg>
          </a>{% endif %}
        </div>
      </div>

      <form class="contact-form" action="https://api.web3forms.com/submit" method="POST">
        <input type="hidden" name="access_key" value="422929a6-5145-4a78-acb5-65c25623672c">
        <input type="hidden" name="subject" value="Новая заявка с сайта Alpha Plast">
        <input type="hidden" name="from_name" value="Сайт Alpha Plast">
        <input type="checkbox" name="botcheck" style="display:none" tabindex="-1" autocomplete="off">
        <h3>{{ site.contact.form_title }}</h3>
        <p>{{ site.contact.form_sub }}</p>

        <div class="calc-note" id="calc-note" hidden>{{ ui.form.calc_added }}</div>

        <div class="form-row">
          <label>{{ ui.form.interest }}</label>
          <div class="form-chips">
            {% for p in site.products.items %}<div class="chip{% if loop.first %} active{% endif %}">{{ p.title }}</div>{% endfor %}
            <div class="chip">{{ ui.form.other }}</div>
          </div>
          <input type="hidden" name="Product" id="chip-value" value="{{ site.products.items[0].title }}">
        </div>

        <div class="form-row two">
          <div>
            <label>{{ ui.form.name }}</label>
            <input type="text" name="Name" class="form-control" placeholder="{{ ui.form.name_ph }}" required>
          </div>
          <div>
            <label>{{ ui.form.company }}</label>
            <input type="text" name="Company" class="form-control" placeholder="{{ ui.form.company_ph }}">
          </div>
        </div>

        <div class="form-row two">
          <div>
            <label>{{ ui.form.phone }}</label>
            <input type="tel" name="Phone" class="form-control" placeholder="{{ ui.form.phone_ph }}" required>
          </div>
          <div>
            <label>{{ ui.form.qty }}</label>
            <input type="text" name="Quantity" class="form-control" placeholder="{{ ui.form.qty_ph }}">
          </div>
