<!DOCTYPE html>
<html lang="ru">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>{{ title }} — Alpha Plast</title>
<meta name="robots" content="index,follow">
<link rel="icon" type="image/png" href="assets/logo-mark.png">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700&family=Bricolage+Grotesque:wght@600;700&display=swap" rel="stylesheet">
<style>
*{box-sizing:border-box;margin:0;padding:0}
body{background:#F4F1EA;color:#0E1014;font-family:"Plus Jakarta Sans",system-ui,sans-serif;line-height:1.7;font-size:16px;-webkit-font-smoothing:antialiased}
.wrap{max-width:820px;margin:0 auto;padding:36px 24px 80px}
.top{display:flex;justify-content:space-between;align-items:center;margin-bottom:40px;gap:16px;flex-wrap:wrap}
.top img{height:42px;display:block}
.back{font-weight:600;color:#E11E1E;text-decoration:none;font-size:15px}
.back:hover{text-decoration:underline}
h1{font-family:"Bricolage Grotesque",sans-serif;font-size:clamp(28px,5vw,40px);letter-spacing:-.02em;margin-bottom:8px;line-height:1.1}
.upd{color:#6B7280;font-size:14px;margin-bottom:30px}
h2{font-family:"Bricolage Grotesque",sans-serif;font-size:21px;margin:30px 0 10px}
p{margin-bottom:13px;color:#1A1D24}
ul{margin:0 0 14px 22px}
li{margin-bottom:7px;color:#1A1D24}
a{color:#E11E1E}
.note{background:#fff;border:1px solid rgba(14,16,20,.1);border-radius:14px;padding:18px 22px;margin-top:32px;font-size:14px;color:#6B7280}
footer{border-top:1px solid rgba(14,16,20,.1);margin-top:44px;padding-top:22px;color:#6B7280;font-size:14px}
footer a{color:#6B7280}
</style>
</head>
<body>
<div class="wrap">
  <div class="top">
    <a href="./"><img src="assets/logo-full.png" alt="Alpha Plast"></a>
    <a href="./" class="back">← На главную</a>
  </div>
  {{ content | safe }}
  <footer>© 2026 «ALPHA PLAST GROUP FACTORY» MCHJ · <a href="mailto:{{ site.contact.email }}">{{ site.contact.email }}</a></footer>
</div>
</body>
</html>
